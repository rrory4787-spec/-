{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents a member of the Khazain Al-Ard community.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoUrl": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "Post": {
      "title": "Community Post",
      "description": "A post shared by a member on the community feed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoUrl": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" }
      },
      "required": ["id", "authorId", "authorName", "content", "createdAt", "likesCount", "commentsCount"]
    },
    "Comment": {
      "title": "Post Comment",
      "description": "A comment left by a member on a community post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoUrl": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "postId", "authorId", "authorName", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of community member profiles."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of community feed posts."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Sub-collection of comments for a specific post."
    }
  }
}
